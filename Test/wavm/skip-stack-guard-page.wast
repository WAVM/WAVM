;; Like the spec skip-stack-guard-page test, but with enough locals to skip
;; a 16KB guard page (macOS AArch64 page size).
;; The spec test uses 1056 i64 locals (8448 bytes), which only exceeds the 4KB
;; page size on Linux. This test uses 2048 i64 locals (16384 bytes / 16KB) to also
;; cover macOS AArch64 with its 16KB pages.
(module
  (memory 1)
  (export "test-guard-page-skip" (func $test-guard-page-skip))

  (func $test-guard-page-skip
    (param $depth i32)
    (if (i32.eq (local.get $depth) (i32.const 0))
      (then (call $function-with-many-locals))
      (else (call $test-guard-page-skip (i32.sub (local.get $depth) (i32.const 1))))
    )
  )

  (func $function-with-many-locals

